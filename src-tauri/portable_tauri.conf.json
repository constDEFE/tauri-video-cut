{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VideoCut",
  "version": "1.0.0",
  "identifier": "io.github.constdefe.tauri-video-cut",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' blob: data:; media-src 'self' blob:; connect-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "lib/**/*"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mp4",
          "mkv",
          "mov",
          "avi",
          "webm"
        ],
        "name": "Video File",
        "description": "Video cuts handled by VideoCut",
        "role": "Viewer"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "WebView2Runtime"
      },
      "allowDowngrades": true,
      "wix": null
    }
  }
}